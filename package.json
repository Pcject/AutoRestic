    "jsonwebtoken": "^9.0.2",
    "better-sqlite3": "^9.2.2",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}